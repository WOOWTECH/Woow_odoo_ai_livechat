<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Default AI Bot Partner: used as fallback author for AI-generated messages -->
        <record id="partner_ai_bot" model="res.partner">
            <field name="name">AI Assistant</field>
            <field name="active" eval="True"/>
            <field name="is_company" eval="False"/>
            <field name="type">contact</field>
        </record>

        <!-- Scheduled Action: Cleanup old API logs daily -->
        <record id="ir_cron_cleanup_llm_api_logs" model="ir.cron">
            <field name="name">Cleanup LLM API Logs</field>
            <field name="model_id" ref="model_llm_api_log"/>
            <field name="state">code</field>
            <field name="code">model._cleanup_old_logs()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
