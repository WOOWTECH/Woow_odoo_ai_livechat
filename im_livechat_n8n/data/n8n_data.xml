<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- N8N Bot Partner: used as author for AI-generated messages -->
        <record id="partner_n8n_bot" model="res.partner">
            <field name="name">N8N Bot</field>
            <field name="active" eval="True"/>
            <field name="is_company" eval="False"/>
            <field name="type">contact</field>
        </record>

        <!-- Scheduled Action: Cleanup old webhook logs daily -->
        <record id="ir_cron_cleanup_n8n_webhook_logs" model="ir.cron">
            <field name="name">Cleanup N8N Webhook Logs</field>
            <field name="model_id" ref="model_n8n_webhook_log"/>
            <field name="state">code</field>
            <field name="code">model._cleanup_old_logs()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
