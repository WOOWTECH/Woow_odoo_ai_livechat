<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="llm_api_log_view_tree" model="ir.ui.view">
        <field name="name">llm.api.log.tree</field>
        <field name="model">llm.api.log</field>
        <field name="arch" type="xml">
            <list string="API Logs" create="false">
                <field name="timestamp" widget="datetime"/>
                <field name="livechat_channel_id"/>
                <field name="discuss_channel_id"/>
                <field name="model"/>
                <field name="status"
                       decoration-success="status == 'success'"
                       decoration-danger="status == 'error'"
                       decoration-warning="status == 'retry'"/>
                <field name="total_tokens"/>
                <field name="response_time" widget="float" digits="[10,2]"/>
                <field name="retry_count"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="llm_api_log_view_form" model="ir.ui.view">
        <field name="name">llm.api.log.form</field>
        <field name="model">llm.api.log</field>
        <field name="arch" type="xml">
            <form string="API Log" create="false" edit="false">
                <sheet>
                    <group>
                        <group name="basic_info" string="Basic Information">
                            <field name="timestamp"/>
                            <field name="status"/>
                            <field name="model"/>
                            <field name="livechat_channel_id"/>
                            <field name="discuss_channel_id"/>
                        </group>
                        <group name="performance" string="Performance &amp; Usage">
                            <field name="response_time"/>
                            <field name="retry_count"/>
                            <field name="prompt_tokens"/>
                            <field name="completion_tokens"/>
                            <field name="total_tokens"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Request" name="request">
                            <field name="request_payload" widget="text" nolabel="1"/>
                        </page>
                        <page string="Response" name="response">
                            <field name="response_payload" widget="text" nolabel="1"/>
                        </page>
                        <page string="Error" name="error" invisible="status == 'success'">
                            <field name="error_message" widget="text" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="llm_api_log_view_search" model="ir.ui.view">
        <field name="name">llm.api.log.search</field>
        <field name="model">llm.api.log</field>
        <field name="arch" type="xml">
            <search string="Search API Logs">
                <!-- Search Fields -->
                <field name="livechat_channel_id"/>
                <field name="discuss_channel_id"/>
                <field name="model"/>
                <field name="status"/>

                <!-- Filters -->
                <filter name="filter_success" string="Success" domain="[('status', '=', 'success')]"/>
                <filter name="filter_error" string="Error" domain="[('status', '=', 'error')]"/>
                <filter name="filter_retry" string="Retry" domain="[('status', '=', 'retry')]"/>
                <separator/>
                <filter name="filter_today" string="Today"
                        domain="[('timestamp', '&gt;=', context_today().strftime('%Y-%m-%d 00:00:00')),
                                 ('timestamp', '&lt;=', context_today().strftime('%Y-%m-%d 23:59:59'))]"/>
                <filter name="filter_last_7_days" string="Last 7 Days"
                        domain="[('timestamp', '&gt;=', (context_today() - datetime.timedelta(days=7)).strftime('%Y-%m-%d 00:00:00'))]"/>
                <filter name="filter_last_30_days" string="Last 30 Days"
                        domain="[('timestamp', '&gt;=', (context_today() - datetime.timedelta(days=30)).strftime('%Y-%m-%d 00:00:00'))]"/>

                <!-- Group By -->
                <group expand="0" string="Group By">
                    <filter name="group_by_status" string="Status" context="{'group_by': 'status'}"/>
                    <filter name="group_by_model" string="Model" context="{'group_by': 'model'}"/>
                    <filter name="group_by_channel" string="Channel" context="{'group_by': 'livechat_channel_id'}"/>
                    <filter name="group_by_date" string="Date" context="{'group_by': 'timestamp:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="llm_api_log_action" model="ir.actions.act_window">
        <field name="name">API Logs</field>
        <field name="res_model">llm.api.log</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_filter_last_7_days': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_empty_folder">
                No API logs found
            </p>
            <p>
                API logs are automatically created when the AI assistant
                processes livechat messages.
            </p>
        </field>
    </record>

    <!-- Menu Item -->
    <menuitem id="llm_api_log_menu"
              name="AI API Logs"
              parent="im_livechat.livechat_config"
              action="llm_api_log_action"
              sequence="50"/>
</odoo>
