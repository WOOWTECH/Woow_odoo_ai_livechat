<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View: List of webhook logs with key information -->
    <record id="n8n_webhook_log_view_tree" model="ir.ui.view">
        <field name="name">n8n.webhook.log.tree</field>
        <field name="model">n8n.webhook.log</field>
        <field name="arch" type="xml">
            <list string="Webhook Logs" create="false">
                <field name="timestamp" widget="datetime"/>
                <field name="event_type"/>
                <field name="livechat_channel_id"/>
                <field name="session_id"/>
                <field name="status"
                       decoration-success="status == 'success'"
                       decoration-danger="status == 'failed'"
                       decoration-warning="status == 'timeout'"/>
                <field name="response_time"/>
                <field name="http_status"/>
            </list>
        </field>
    </record>

    <!-- Form View: Detailed view of a single webhook log -->
    <record id="n8n_webhook_log_view_form" model="ir.ui.view">
        <field name="name">n8n.webhook.log.form</field>
        <field name="model">n8n.webhook.log</field>
        <field name="arch" type="xml">
            <form string="Webhook Log" create="false" edit="false">
                <sheet>
                    <group>
                        <group name="basic_info" string="Basic Information">
                            <field name="timestamp"/>
                            <field name="event_type"/>
                            <field name="status"/>
                            <field name="livechat_channel_id"/>
                            <field name="session_id"/>
                        </group>
                        <group name="performance" string="Performance">
                            <field name="response_time"/>
                            <field name="http_status"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Request" name="request">
                            <field name="request_payload" widget="text" nolabel="1"/>
                        </page>
                        <page string="Response" name="response">
                            <field name="response_payload" widget="text" nolabel="1"/>
                        </page>
                        <page string="Error" name="error" invisible="status == 'success'">
                            <field name="error_message" widget="text" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View: Filters and grouping options -->
    <record id="n8n_webhook_log_view_search" model="ir.ui.view">
        <field name="name">n8n.webhook.log.search</field>
        <field name="model">n8n.webhook.log</field>
        <field name="arch" type="xml">
            <search string="Search Webhook Logs">
                <!-- Search Fields -->
                <field name="livechat_channel_id"/>
                <field name="session_id"/>
                <field name="event_type"/>
                <field name="status"/>

                <!-- Filters -->
                <filter name="filter_outbound" string="Outbound" domain="[('event_type', '=', 'outbound')]"/>
                <filter name="filter_inbound" string="Inbound" domain="[('event_type', '=', 'inbound')]"/>
                <separator/>
                <filter name="filter_success" string="Success" domain="[('status', '=', 'success')]"/>
                <filter name="filter_failed" string="Failed" domain="[('status', '=', 'failed')]"/>
                <filter name="filter_timeout" string="Timeout" domain="[('status', '=', 'timeout')]"/>
                <separator/>
                <filter name="filter_today" string="Today"
                        domain="[('timestamp', '&gt;=', context_today().strftime('%Y-%m-%d 00:00:00')),
                                 ('timestamp', '&lt;=', context_today().strftime('%Y-%m-%d 23:59:59'))]"/>
                <filter name="filter_last_7_days" string="Last 7 Days"
                        domain="[('timestamp', '&gt;=', (context_today() - datetime.timedelta(days=7)).strftime('%Y-%m-%d 00:00:00'))]"/>
                <filter name="filter_last_30_days" string="Last 30 Days"
                        domain="[('timestamp', '&gt;=', (context_today() - datetime.timedelta(days=30)).strftime('%Y-%m-%d 00:00:00'))]"/>

                <!-- Group By -->
                <group expand="0" string="Group By">
                    <filter name="group_by_event_type" string="Direction" context="{'group_by': 'event_type'}"/>
                    <filter name="group_by_status" string="Status" context="{'group_by': 'status'}"/>
                    <filter name="group_by_channel" string="Channel" context="{'group_by': 'livechat_channel_id'}"/>
                    <filter name="group_by_date" string="Date" context="{'group_by': 'timestamp:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action: Open webhook logs -->
    <record id="n8n_webhook_log_action" model="ir.actions.act_window">
        <field name="name">Webhook Logs</field>
        <field name="res_model">n8n.webhook.log</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_filter_last_7_days': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_empty_folder">
                No webhook logs found
            </p>
            <p>
                Webhook logs are automatically created when webhooks are sent to or received from n8n.
            </p>
        </field>
    </record>

    <!-- Menu Item: Under Live Chat > Configuration -->
    <menuitem id="n8n_webhook_log_menu"
              name="Webhook Logs"
              parent="im_livechat.livechat_config"
              action="n8n_webhook_log_action"
              sequence="50"/>
</odoo>
