<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="im_livechat_channel_view_form_inherit_n8n" model="ir.ui.view">
        <field name="name">im_livechat.channel.form.inherit.n8n</field>
        <field name="model">im_livechat.channel</field>
        <field name="inherit_id" ref="im_livechat.im_livechat_channel_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="N8N Integration" name="n8n_integration">
                    <group>
                        <group string="Webhook Configuration">
                            <field name="n8n_enabled"/>
                            <field name="n8n_webhook_url"
                                   placeholder="https://your-n8n.com/webhook/abc123"
                                   invisible="not n8n_enabled"/>
                        </group>
                        <group string="Authentication" invisible="not n8n_enabled">
                            <field name="n8n_api_key" widget="CopyClipboardChar"/>
                            <button name="action_regenerate_api_key"
                                    string="Regenerate API Key"
                                    type="object"
                                    class="btn-secondary"
                                    confirm="This will invalidate the current API key. Continue?"/>
                        </group>
                        <group string="Advanced Settings" invisible="not n8n_enabled">
                            <field name="n8n_max_retries"/>
                            <field name="n8n_timeout"/>
                        </group>
                    </group>
                    <group invisible="not n8n_enabled">
                        <button name="action_test_webhook"
                                string="Test Webhook Connection"
                                type="object"
                                class="btn-primary"/>
                        <button name="action_view_webhook_logs"
                                string="View Webhook Logs"
                                type="object"
                                class="btn-link"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
